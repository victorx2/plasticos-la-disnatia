# Copiar a .env en la raíz del proyecto (junto a docker-compose.yml)
#   copy .env.docker.example .env

# --- MySQL (contenedor db) ---
MYSQL_ROOT_PASSWORD=cambiar_root_seguro
MYSQL_DATABASE=axones
MYSQL_USER=axones
MYSQL_PASSWORD=cambiar_clave_bd_segura

# --- API ---
# Mínimo 32 caracteres. Generar: openssl rand -hex 32
JWT_SECRET=cambiar_esta_clave_por_una_de_al_menos_32_caracteres
JWT_EXPIRE_MINUTES=480

# URLs desde donde abrirán la app (IP de la PC servidor + puerto web)
# Ejemplo red local: http://192.168.0.50:8080
# Varios orígenes separados por coma:
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Puerto público de la aplicación (frontend + proxy /api)
APP_PORT=8080
