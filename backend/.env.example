# Base de datos MySQL (producción)
DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/axones

# Entorno: development | production
ENVIRONMENT=production

# API
API_HOST=0.0.0.0
API_PORT=8000

# Seguridad — obligatorio en producción (≥32 caracteres)
JWT_SECRET=
JWT_EXPIRE_MINUTES=480

# Requerir Bearer token en todos los endpoints (excepto /api/auth/login y /up)
API_REQUIRE_AUTH=true

# CORS — URL(s) del frontend separadas por coma
# Ejemplo: https://app.tudominio.com,https://www.tudominio.com
CORS_ORIGINS=https://app.tudominio.com
