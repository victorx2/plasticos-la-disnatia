# Plantilla para producción en la nube
# El desarrollador copia esto a .env y rellena los valores antes de enviárselo a quien hace el deploy

MYSQL_ROOT_PASSWORD=GENERAR_CLAVE_SEGURA
MYSQL_DATABASE=axones
MYSQL_USER=axones
MYSQL_PASSWORD=GENERAR_CLAVE_SEGURA

JWT_SECRET=GENERAR_MINIMO_32_CARACTERES
JWT_EXPIRE_MINUTES=480

# Cambiar por el dominio real que compren
CORS_ORIGINS=https://axonesacarigua.com,https://www.axonesacarigua.com

APP_PORT=8080
